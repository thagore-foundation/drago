import lib.fs as fs
import lib.map as map
import lib.path as path
import lib.toml as toml
import std.list as list
import std.string as str
import src.core.utils as utils

pub func manifest_path(project_root: ptr) -> ptr:
  return path.join(project_root, "drago.toml")

pub func default_name() -> ptr:
  return str.concat("", "app")

pub func default_version() -> ptr:
  return str.concat("", "0.1.0")

pub func default_entry() -> ptr:
  return str.concat("", "src/main.tg")

pub func default_description() -> ptr:
  return str.concat("", "")

pub func default_license() -> ptr:
  return str.concat("", "MIT")

pub func default_authors() -> ptr:
  return str.concat("", "")

pub func parse_handle(project_root: ptr) -> ptr:
  let p = manifest_path(project_root)
  if (fs.exists(p) == 0):
    return toml.toml_parse(str.concat("", ""))
  let raw = fs.read_file(p)
  if (map.map_is_null_ptr(raw) == 1):
    return toml.toml_parse(str.concat("", ""))
  return toml.toml_parse(raw)

pub func load_name(project_root: ptr) -> ptr:
  let h = parse_handle(project_root)
  if (map.map_is_null_ptr(h) == 1):
    return default_name()
  let pkg = toml.toml_get_section(h, "package")
  let out = toml.toml_get_str(pkg, "name")
  if (map.map_is_null_ptr(out) == 1):
    toml.toml_free(h)
    return default_name()
  if (utils.is_empty(out)):
    toml.toml_free(h)
    return default_name()
  toml.toml_free(h)
  return out

pub func load_version(project_root: ptr) -> ptr:
  let h = parse_handle(project_root)
  if (map.map_is_null_ptr(h) == 1):
    return default_version()
  let pkg = toml.toml_get_section(h, "package")
  let out = toml.toml_get_str(pkg, "version")
  if (map.map_is_null_ptr(out) == 1):
    toml.toml_free(h)
    return default_version()
  if (utils.is_empty(out)):
    toml.toml_free(h)
    return default_version()
  toml.toml_free(h)
  return out

