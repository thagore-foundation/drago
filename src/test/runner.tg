import lib.fs as fs
import lib.map as map
import lib.path as path
import lib.process as process
import lib.time as time
import std.list as list
import std.string as str
import src.core.utils as utils
import src.cli.output as out
import src.build.linker as linker
import src.project.manifest as manifest

pub func is_test_file(name: ptr) -> i32:
  if (utils.utils_contains(name, "test")):
    if (utils.ends_with(name, ".tg")):
      return 1
  return 0

pub func discover_tests(project_root: ptr) -> ptr:
  let out = list.list_new()
  let tests_dir = path.join(project_root, "tests")
  if (fs.exists(tests_dir) == 0):
    return out
  let files = fs.readdir(tests_dir)
  if (map.map_is_null_ptr(files) == 1):
    return out
  let i: i64 = 0
  let n = list.list_count(files)
  while (i < n):
    let name = list.list_get(files, i)
    if (is_test_file(name) != 0):
      list.list_append(out, path.join(tests_dir, name))
    i = i + 1
  return out

pub func run_tests(project_root: ptr, quiet: i32) -> i32:
  out.print_action("🧪", str.concat("Testing ", str.concat(manifest.load_name(project_root), str.concat(" v", manifest.load_version(project_root)))), quiet)
  let tests = discover_tests(project_root)
  let n = list.list_count(tests)
  if (n == 0):
    out.print_warning("No tests found", quiet)
    return 1

  let target_dir = path.join(project_root, "target")
  fs.mkdir(target_dir)

  let started_all = time.now_ms()
  let i: i64 = 0
  let ok: i32 = 1
  let passed: i64 = 0
  let failed: i64 = 0
  while (i < n):
    let test_file = list.list_get(tests, i)
    let out_bin = path.join(target_dir, str.concat("test_", str.concat(str.from_int(i), ".bin")))
    let cmd_build = str.concat(linker.thagc_bin(), str.concat(" build ", str.concat(test_file, str.concat(" -o ", out_bin))))
    let start = time.now_ms()
    if (process.run(cmd_build) != 0):
      out.print_error(str.concat(test_file, " (compile failed)"))
      ok = 0
      failed = failed + 1
      i = i + 1
      continue
    let run_rc = process.run(out_bin)
    let elapsed = time.now_ms() - start
    if (run_rc == 0):
      passed = passed + 1
      out.print_done(test_file, out.format_ms(elapsed), quiet)
    else:
      failed = failed + 1
      out.print_error(str.concat(test_file, str.concat(" (exit=", str.concat(str.from_int(run_rc), ")"))))
      print(str.concat("    │ at: ", test_file))
      ok = 0
    i = i + 1
  print("")
  let total_elapsed = time.now_ms() - started_all
  print(str.concat("  ", str.concat(str.from_int(passed), str.concat(" passed  ", str.concat(str.from_int(failed), str.concat(" failed  ", out.format_ms(total_elapsed)))))))
  return ok
