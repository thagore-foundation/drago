import lib.fs as fs
import lib.path as path
import lib.process as process
import std.list as list
import std.string as str
import src.deps.cache as cache
import src.deps.downloader as downloader
import src.project.lockfile as lockfile
import src.project.manifest as manifest

func expect_true(ok: bool, label: ptr) -> i32:
  if (ok):
    return 1
  print(str.concat("FAIL ", label))
  return 0

func quoted(text: ptr) -> ptr:
  return str.concat("\"", str.concat(text, "\""))

func write_basic_manifest(root: ptr, name: ptr, version: ptr) -> i32:
  let raw = str.concat("[package]\n", "")
  raw = str.concat(raw, str.concat("name = \"", str.concat(name, "\"\n")))
  raw = str.concat(raw, str.concat("version = \"", str.concat(version, "\"\n")))
  raw = str.concat(raw, "entry = \"src/main.tg\"\n")
  raw = str.concat(raw, "description = \"\"\n")
  raw = str.concat(raw, "license = \"MIT\"\n")
  raw = str.concat(raw, "authors = \"\"\n\n")
  raw = str.concat(raw, "[dependencies]\n")
  return fs.write_file(path.join(root, "drago.toml"), raw)

func run_cmd(cmd: ptr) -> i32:
  let rc = process.run(cmd)
  if (rc != 0):
    print(str.concat("FAIL command: ", cmd))
    return 0
  return 1

func find_dep_line(lines: ptr, dep_name: ptr) -> ptr:
  let i: i64 = 0
  let n = list.list_count(lines)
  while (i < n):
    let line = list.list_get(lines, i)
    if (str.str_eq(manifest.dependency_name(line), dep_name)):
      return line
    i = i + 1
  return str.concat("", "")

func find_lock_line(lines: ptr, dep_name: ptr) -> ptr:
  let i: i64 = 0
  let n = list.list_count(lines)
  while (i < n):
    let line = list.list_get(lines, i)
    if (str.str_eq(lockfile.pkg_name(line), dep_name)):
      return line
    i = i + 1
  return str.concat("", "")

func test_external_sources() -> i32:
  let cwd = fs.getcwd()
  let tmp = path.join(cwd, "tmp_external_sources_test")
  let app_root = path.join(tmp, "app")
  let path_dep_root = path.join(tmp, "pathdep")
  let git_dep_root = path.join(tmp, "gitdep")
  let git_cache_root = cache.package_dir("gitdep", "main")
  let path_cache_root = cache.package_dir("pathdep", "0.3.0")

  fs.remove_path(tmp)
  fs.remove_path(git_cache_root)
  fs.remove_path(path_cache_root)
  fs.mkdir(tmp)
  fs.mkdir(app_root)
  fs.mkdir(path_dep_root)
  fs.mkdir(git_dep_root)

  if (write_basic_manifest(app_root, "app", "0.1.0") == 0):
    print("FAIL write app manifest")
    return 1
  if (write_basic_manifest(path_dep_root, "pathdep", "0.3.0") == 0):
    print("FAIL write path manifest")
    return 2
  if (write_basic_manifest(git_dep_root, "gitdep", "0.4.0") == 0):
    print("FAIL write git manifest")
    return 3

  fs.write_file(path.join(path_dep_root, "lib.tg"), "func main() -> i32:\n  return 0\n")
  fs.write_file(path.join(git_dep_root, "README.txt"), "v1\n")

  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " init"))) == 0):
    return 4
  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " branch -M main"))) == 0):
    return 5
  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " config user.email test@example.com"))) == 0):
    return 6
  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " config user.name test-user"))) == 0):
    return 7
  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " add ."))) == 0):
    return 8
  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " commit -m init"))) == 0):
    return 9

  if (downloader.install_path_package("pathdep", "0.3.0", path_dep_root) == 0):
    print("FAIL install path dependency")
    return 10
  if (manifest.add_dependency(app_root, "pathdep", manifest.external_dep_spec("path", "0.3.0", path_dep_root)) == 0):
    print("FAIL save path dependency")
    return 11
  if (lockfile.upsert(app_root, "pathdep", "0.3.0", str.concat("path:", path_dep_root), str.concat("", "")) == 0):
    print("FAIL lock path dependency")
    return 12
  if (downloader.install_git_package("gitdep", "main", git_dep_root, 0) == 0):
    print("FAIL install git dependency")
    return 13
  if (manifest.add_dependency(app_root, "gitdep", manifest.external_dep_spec("git", "main", git_dep_root)) == 0):
    print("FAIL save git dependency")
    return 14
  if (lockfile.upsert(app_root, "gitdep", "main", str.concat("git:", git_dep_root), str.concat("", "")) == 0):
    print("FAIL lock git dependency")
    return 15

  let deps = manifest.load_dependencies(app_root)
  let path_line = find_dep_line(deps, "pathdep")
  let git_line = find_dep_line(deps, "gitdep")
  if (expect_true(str.str_eq(manifest.dependency_source_kind(path_line), "path"), "path source kind") == 0):
    return 16
  if (expect_true(str.str_eq(manifest.dependency_version_value(path_line), "0.3.0"), "path source version") == 0):
    return 17
  if (expect_true(str.str_eq(manifest.dependency_source_kind(git_line), "git"), "git source kind") == 0):
    return 18
  if (expect_true(str.str_eq(manifest.dependency_version_value(git_line), "main"), "git ref version") == 0):
    return 19

  let locks = lockfile.load_lines(app_root)
  let path_lock = find_lock_line(locks, "pathdep")
  let git_lock = find_lock_line(locks, "gitdep")
  if (expect_true(str.str_eq(lockfile.pkg_source(path_lock), str.concat("path:", path_dep_root)), "path lock source") == 0):
    return 20
  if (expect_true(str.str_eq(lockfile.pkg_source(git_lock), str.concat("git:", git_dep_root)), "git lock source") == 0):
    return 21

  let cached_git_file = path.join(git_cache_root, "README.txt")
  if (expect_true(str.str_eq(str.trim(fs.read_file(cached_git_file)), "v1"), "git cache initial clone") == 0):
    return 22

  fs.write_file(path.join(git_dep_root, "README.txt"), "v2\n")
  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " add README.txt"))) == 0):
    return 23
  if (run_cmd(str.concat("git -C ", str.concat(quoted(git_dep_root), " commit -m update"))) == 0):
    return 24

  if (downloader.install_git_package("gitdep", "main", git_dep_root, 0) == 0):
    print("FAIL reinstall git dependency")
    return 25
  if (expect_true(str.str_eq(str.trim(fs.read_file(cached_git_file)), "v2"), "git cache refresh on install") == 0):
    return 26

  fs.remove_path(tmp)
  return 0

func main() -> i32:
  return test_external_sources()
