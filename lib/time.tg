# Time helpers mapped to runtime hooks.

extern func thag_now_ms() -> i64
extern func thag_sleep_ms(millis: i64) -> void

pub func now_ms() -> i64:
  return thag_now_ms()

pub func sleep_ms(millis: i64) -> i32:
  thag_sleep_ms(millis)
  return 0

pub func now() -> i64:
  return now_ms()

pub func sleep(millis: i64) -> i32:
  return sleep_ms(millis)
