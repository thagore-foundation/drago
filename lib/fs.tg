# File-system helpers mapped to runtime hooks.

extern func thag_fs_read(path: ptr) -> ptr
extern func thag_fs_write(path: ptr, content: ptr) -> i32
extern func thag_fs_exists(path: ptr) -> i32
extern func thag_fs_mkdir(path: ptr) -> i32
extern func thag_fs_readdir(path: ptr) -> ptr
extern func thag_fs_remove(path: ptr) -> i32
extern func thag_fs_getcwd() -> ptr
extern func thag_fs_path_join(a: ptr, b: ptr) -> ptr
extern func thag_fs_is_dir(path: ptr) -> i32
extern func thag_fs_filesize(path: ptr) -> i64

pub func read(path: ptr) -> ptr:
  return thag_fs_read(path)

pub func read_file(path: ptr) -> ptr:
  return thag_fs_read(path)

pub func write(path: ptr, content: ptr) -> i32:
  return thag_fs_write(path, content)

pub func write_file(path: ptr, content: ptr) -> i32:
  return thag_fs_write(path, content)

pub func exists(path: ptr) -> i32:
  return thag_fs_exists(path)

pub func mkdir(path: ptr) -> i32:
  return thag_fs_mkdir(path)

pub func readdir(path: ptr) -> ptr:
  return thag_fs_readdir(path)

pub func fs_remove(path: ptr) -> i32:
  return thag_fs_remove(path)

pub func remove_path(path: ptr) -> i32:
  return thag_fs_remove(path)

pub func getcwd() -> ptr:
  return thag_fs_getcwd()

pub func path_join(a: ptr, b: ptr) -> ptr:
  return thag_fs_path_join(a, b)

pub func is_dir(path: ptr) -> i32:
  return thag_fs_is_dir(path)

pub func filesize(path: ptr) -> i64:
  return thag_fs_filesize(path)
